# =============================================================================
# BioAgents — environment configuration
#
# Copy this file to `.env` and fill in the values you actually need. Only the
# LLM provider block is strictly required; everything else unlocks an optional
# tool or external MCP server.
#
#   cp .env.template .env
#   docker compose up --build
# =============================================================================

# ---------------------------------------------------------------------------
# LLM provider (pick one: openai | gemini | ollama)
# ---------------------------------------------------------------------------
LLM_PROVIDER=gemini

OPENAI_API_KEY=
GEMINI_API_KEY=
GEMINI_RATE_LIMIT=5

# Ollama (only when LLM_PROVIDER=ollama). Use host.docker.internal from inside
# the container to reach a local Ollama daemon running on the host.
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1

# ---------------------------------------------------------------------------
# Runtime behaviour
# ---------------------------------------------------------------------------
# Port the FastAPI UI binds on the host (container always listens on 8000).
BIOAGENTS_PORT=8000

# Number of uvicorn workers. Bump for concurrent traffic.
WEB_CONCURRENCY=1

# When "true", the coder/ml/dl agents execute code in-process using
# smolagents.LocalPythonExecutor. When "false", the DockerExecutor spawns
# nested containers — mount /var/run/docker.sock in docker-compose.yml first.
USE_LOCAL_EXECUTOR=true

# ---------------------------------------------------------------------------
# Observability — LangSmith (optional)
# ---------------------------------------------------------------------------
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=bioagents

# ---------------------------------------------------------------------------
# ToolUniverse MCP integrations (optional, leave blank to disable)
# ---------------------------------------------------------------------------
BOLTZ_MCP_SERVER_HOST=
EXPERT_FEEDBACK_MCP_SERVER_URL=
HF_TOKEN=
TXAGENT_MCP_SERVER_HOST=
USPTO_API_KEY=
USPTO_MCP_SERVER_HOST=
